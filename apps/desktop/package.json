{
  "name": "@gitwand/desktop",
  "version": "3.2.0",
  "private": true,
  "description": "GitWand Desktop — lightweight Git client with smart conflict resolution (Tauri + Vue 3)",
  "type": "module",
  "scripts": {
    "dev": "node scripts/copy-grammars.mjs && vite",
    "dev:server": "node dev-server.mjs",
    "dev:web": "concurrently -k -n api,vite -c blue,green \"node dev-server.mjs\" \"node scripts/copy-grammars.mjs && vite\"",
    "copy-grammars": "node scripts/copy-grammars.mjs",
    "build": "node scripts/copy-grammars.mjs && vue-tsc --noEmit && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:parity": "vitest run --config vitest.config.parity.ts",
    "bench": "cd src-tauri && cargo build --example parity-probe --release && cd .. && node perf/bench.mjs",
    "bench:check": "cd src-tauri && cargo build --example parity-probe --release && cd .. && node perf/bench.mjs --check-against perf/baseline.json",
    "bench:write-baseline": "cd src-tauri && cargo build --example parity-probe --release && cd .. && node perf/bench.mjs --write-baseline perf/baseline.json",
    "bundle-check": "node perf/bundle-check.mjs",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@codemirror/commands": "^6.10.4",
    "@codemirror/language": "^6.12.4",
    "@codemirror/language-data": "^6.5.2",
    "@codemirror/state": "^6.7.0",
    "@codemirror/theme-one-dark": "^6.1.3",
    "@codemirror/view": "^6.43.4",
    "@gitwand/core": "workspace:*",
    "@tanstack/vue-virtual": "^3.13.24",
    "@tauri-apps/api": "^2.11.1",
    "@tauri-apps/plugin-clipboard-manager": "^2.3.2",
    "@tauri-apps/plugin-notification": "^2.3.3",
    "@tauri-apps/plugin-process": "^2.3.1",
    "@tauri-apps/plugin-updater": "^2.10.1",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-search": "^0.15.0",
    "@xterm/addon-web-links": "^0.11.0",
    "@xterm/addon-webgl": "^0.19.0",
    "@xterm/xterm": "^6.0.0",
    "codemirror": "^6.0.2",
    "dompurify": "^3.4.11",
    "highlight.js": "^11.11.1",
    "markdown-it": "^14.2.0",
    "tree-sitter-wasms": "^0.1.13",
    "vue": "^3.5.0",
    "web-tree-sitter": "^0.26.8"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.11.4",
    "@types/markdown-it": "^14.1.2",
    "@vitejs/plugin-vue": "^5.2.0",
    "concurrently": "^9.0.0",
    "jsdom": "^25.0.0",
    "node-pty": "^1.1.0",
    "typescript": "^5.4.0",
    "vite": "^6.4.3",
    "vitest": "^4.1.0",
    "vue-tsc": "^2.1.0"
  },
  "license": "MIT"
}
